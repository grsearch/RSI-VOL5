# ── API Keys ─────────────────────────────────────────────────────
BIRDEYE_API_KEY=                   # B-05 级别，支持 WebSocket 实时价格推送

# ── Helius 配置（Business 级别） ──────────────────────────────────
#
# ★ WebSocket 连接优先级（用于链上交易监听）：
#   Gatekeeper WSS (beta) > HELIUS_WSS_URL > 自动拼接
#
# ★ LaserStream 是 gRPC 协议，不是 WebSocket！
#   仅用于 trader.js 的 RPC 发单加速，不能用于 transactionSubscribe。
#   如果只配置了 LaserStream 而没配 WSS_URL，程序会自动用 API Key 拼接 WSS 端点。
#
# Enhanced WebSocket（链上交易监听 — 必须配置）
HELIUS_WSS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
#
# Gatekeeper（beta — WebSocket 最低延迟，同时也用于 RPC 发单）
HELIUS_GATEKEEPER_URL=https://beta.helius-rpc.com/?api-key=YOUR_KEY
#
# LaserStream（gRPC，仅用于 RPC 发单加速，不用于 WebSocket 订阅）
# HELIUS_LASERSTREAM_URL=https://laserstream-mainnet-fra.helius-rpc.com
#
# 标准 RPC（兜底）
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_API_KEY=                    # 备用，如果上面 URL 中已含 api-key 可不填
#
# ★ WebSocket 订阅模式（影响 credits 消耗）
#   "token" = 按 token mint 精准订阅（最省，默认）
#   "pump"  = 订阅 Pump AMM 全局，本地过滤（适合只做 Pump.fun 迁移币）
HELIUS_SUB_MODE=token

# ── Jupiter ──────────────────────────────────────────────────────
JUPITER_API_URL=https://api.jup.ag
JUPITER_API_KEY=

# ── 钱包 ─────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=                # Base58 私钥（DRY_RUN 模式下可留空）

# ── 交易参数 ──────────────────────────────────────────────────────
TRADE_SIZE_SOL=0.2
SLIPPAGE_BPS=500                   # 默认滑点（bps）
SLIPPAGE_MAX_BPS=2000              # 最大滑点（重试时递增）
TRADE_MAX_RETRY=3                  # 交易重试次数（止损时自动减少）
PRIORITY_FEE_MICROLAMPORTS=100000  # 默认 priority fee（动态获取失败时的兜底值）

# ── 策略参数 ──────────────────────────────────────────────────────
RSI_PERIOD=9
RSI_BUY_LEVEL=35                   # RSI < 此值 + 量能确认 → 买入
RSI_SELL_LEVEL=70                   # RSI 下穿此值 → 卖出
RSI_PANIC_LEVEL=80                  # RSI > 此值 → 立即卖出

# ── 量能过滤参数 ──────────────────────────────────────────────────
VOL_ENABLED=true                   # 是否启用量能过滤
VOL_BUY_MULT=1.2                   # 买入条件：buyVol >= N × sellVol
VOL_SELL_MULT=999                  # 卖出条件：sellVol >= N × buyVol（卖压超过买压）
VOL_MIN_TOTAL=5                   # 买入条件：窗口内总成交量(buyVol+sellVol) >= N SOL
VOL_WINDOW_SEC=120                 # 买入确认窗口（秒）：2分钟窗口内 buyVol > sellVol 才买入
VOL_EXIT_CONSECUTIVE=3             # 持仓中连续N根K线量能萎缩则出场（5秒K线×3=15秒）
VOL_EXIT_RATIO=0.3                 # 量能萎缩阈值：当前量 < 均量 × 0.3 视为萎缩（30%）
VOL_EXIT_LOOKBACK=4                # 萎缩出场均量回看K线数
SKIP_FIRST_CANDLES=8               # 跳过前N根K线不交易（15秒K线×8=2分钟）

# ── K线 & 轮询 ────────────────────────────────────────────────────
KLINE_INTERVAL_SEC=60              # K线宽度（秒）— 1分钟K线
PRICE_POLL_SEC=1                   # 价格轮询间隔（秒）— 止损由 WS 实时驱动，此参数仅影响 RSI 刷新
SL_POLL_SEC=60                     # 止盈止损轮询间隔（秒）— 1分钟

TAKE_PROFIT_PCT=99999              # 止盈百分比（设极大值=关闭止盈）
STOP_LOSS_PCT=-20                  # 固定止损百分比（负数）
# ★ 止损执行路径：Birdeye WS 价格推送（<150ms）→ 本地判断 → Helius Sender（<350ms）
#    总延迟目标 <500ms

# ── 移动止损（Trailing Stop）──────────────────────────────────────
TRAILING_STOP_ENABLED=true         # 是否开启移动止损
TRAILING_STOP_ACTIVATE=30          # 上涨达到此幅度(%)后激活移动止损
TRAILING_STOP_PCT=-20              # 从峰值回撤超过此幅度(%)则清仓

# ── 监控参数 ──────────────────────────────────────────────────────
SELL_COOLDOWN_SEC=30               # 卖出后冷却时间（秒），防止同一信号重复买入
FDV_EXIT_USD=10000
MIN_FDV_USD=15000
MIN_LP_USD=5000

# ── 空跑模式 ──────────────────────────────────────────────────────
DRY_RUN=true                       # true=不实际交易，只记录信号和模拟盈亏
DRY_RUN_DATA_DIR=./data            # 空跑数据持久化目录

# ── 服务器 ────────────────────────────────────────────────────────
PORT=3001
LOG_LEVEL=info
